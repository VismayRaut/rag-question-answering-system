# ── LLM Configuration ──────────────────────────────────────────────────────
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ── Embedding ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking ──────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────────────────────
TOP_K=5
MIN_SIMILARITY_THRESHOLD=0.3

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── Paths ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
FAISS_INDEX_PATH=vector_store/faiss.index
FAISS_META_PATH=vector_store/faiss_meta.json
